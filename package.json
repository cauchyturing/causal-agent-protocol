{
  "name": "@abel-ai/cap-bridge",
  "version": "0.1.0",
  "description": "CAP v0.2.2 protocol spec + MCP bridge for the Causal Agent Protocol",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cap": "./dist/cap/index.js",
    "./cap/*": "./dist/cap/*.js",
    "./errors": "./dist/cap/errors.js"
  },
  "bin": {
    "cap-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:stdio": "tsx src/index.ts --stdio",
    "lint": "eslint src/ tests/ --max-warnings 0",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:conformance": "vitest run tests/conformance/",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run format:check && npm run test:unit",
    "check:all": "npm run lint && npm run format:check && npm run test",
    "typecheck": "tsc --noEmit",
    "structural": "vitest run tests/structural/"
  },
  "keywords": [
    "causal",
    "agent",
    "protocol",
    "cap",
    "mcp",
    "abel"
  ],
  "author": "Abel AI",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
