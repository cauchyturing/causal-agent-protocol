# Required
CAP_ENDPOINT=https://your-cap-server.com

# Auth
CAP_API_KEY=
CAP_ACCESS_TIER=standard                # public | standard | enterprise

# Server
CAP_PORT=3001
CAP_LOG_LEVEL=info

# Security
CAP_RATE_LIMIT_PUBLIC=100
CAP_RATE_LIMIT_STANDARD=1000
CAP_RATE_LIMIT_ENTERPRISE=10000
CAP_MAX_SUBGRAPH_EDGES=50
